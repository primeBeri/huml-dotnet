{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(claude mcp add:*)",
      "Bash(pwsh:*)",
      "Bash(powershell.exe:*)",
      "Bash(git checkout:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet sln add:*)",
      "Bash(dotnet add:*)",
      "Bash(git add:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet ef:*)",
      "Bash(dotnet build:*)",
      "Bash(powershell:*)",
      "Bash(git log:*)",
      "Bash(Select-String -Pattern \"warn:|error:|Done\")",
      "Bash(gh repo rename:*)",
      "WebSearch",
      "SlashCommand(/docs.review)",
      "Bash(python scripts/docs/validate-links.py:*)",
      "Bash(pwsh.exe -Command:*)",
      "Bash(git rev-parse:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:aspire.dev)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "Bash(find:*)",
      "Bash(findstr:*)",
      "Bash(rm:*)",
      "Bash(git rm:*)",
      "Bash(dir:*)",
      "Skill(superpowers:executing-plans)",
      "Skill(superpowers:*)",
      "Bash(dotnet --list-sdks:*)",
      "Bash(dotnet restore:*)",
      "Bash(xargs:*)",
      "Bash(docker volume:*)",
      "Bash(aspire run:*)",
      "Bash(docker stop:*)",
      "Bash(docker rm:*)",
      "Bash(timeout:*)",
      "Bash(docker ps:*)",
      "Bash(dotnet user-secrets:*)",
      "Bash(docker logs:*)",
      "Bash",
      "mcp__task-master-ai__get_task",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)",
      "mcp__backlog__task_view",
      "mcp__backlog__task_list",
      "mcp__backlog__task_edit",
      "mcp__backlog__task_create",
      "Skill(plugin-dev:create-plugin)",
      "Skill(plugin-dev:plugin-structure)",
      "Skill(plugin-dev:agent-development)",
      "mcp__context7__invoke_command",
      "mcp__context7__list_commands"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "aspire",
    "context7",
    "playwright",
    "dotnet-metadata"
  ],
  "outputStyle": "Explanatory",
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true
  }
}
